# Copy this file to .env.local for local development, or set the same
# variables in your Vercel project settings for production.
# Variables WITHOUT the NEXT_PUBLIC_ prefix are server-side only and
# should never appear in client bundles.

# --- Supabase ---
# Server-side waitlist + contributor submissions write to Supabase.
# Get from Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
# Powers the welcome email + contributor reply.
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Optional. Once your domain is verified in Resend, switch to a
# branded sender like "Dars <hello@darsapp.com>". Defaults to
# "Dars <onboarding@resend.dev>" when unset.
RESEND_FROM=

# --- Google Analytics 4 ---
# Measurement ID, e.g. G-XXXXXXXXXX. When set, gtag.js is loaded by
# layout.tsx. Leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=

# --- Dev-only ---
# When set to "1", the waitlist form simulates a successful submission
# without hitting /api/waitlist. Useful for screenshotting / styling.
# NEXT_PUBLIC_WAITLIST_MOCK=

# --- Clerk (account deletion page) ---
# Used by /delete-account so users can sign in with the same Clerk
# instance as the Expo app and hard-delete their account.
# Get from Clerk dashboard → API keys. Use the SAME instance as the app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase Edge Functions ---
# Host for the account-delete edge function. Format:
#   https://<project-ref>.functions.supabase.co
SUPABASE_FUNCTIONS_URL=
